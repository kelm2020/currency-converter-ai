{
  "name": "currency-converter-challenge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare": "is-ci || husky",
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --fix --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "audit:architecture": "node scripts/architecture-observer.mjs",
    "audit:contracts": "node scripts/zod-contract-guardian.mjs",
    "sync:ai-context": "node scripts/ai-context-sync.mjs",
    "check:ai-context": "node scripts/ai-context-sync.mjs --check",
    "report:react19": "node scripts/react19-modernization-report.mjs",
    "sync:ai-first": "npm run sync:ai-context && npm run report:react19",
    "check:ai-first": "npm run audit:architecture && npm run audit:contracts && npm run check:ai-context",
    "maintain:ai-first": "node scripts/ai-first-maintainer.mjs",
    "fix:ai-first": "node scripts/ai-first-maintainer.mjs --apply-safe-fixes",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "npx playwright install --with-deps",
    "test:e2e:report": "npx playwright show-report",
    "test:ui": "vitest --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "clsx": "^2.1.1",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^15.1.0",
    "next-intl": "^4.9.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-app": "^12.1.0",
    "@storybook/addon-a11y": "8.6.14",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/addon-links": "8.6.14",
    "@storybook/builder-vite": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@storybook/testing-library": "0.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/query-sync-storage-persister": "^5.99.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-persist-client": "^5.99.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.7",
    "@vitest/ui": "^3.0.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.4",
    "prettier": "^3.8.3",
    "size-limit": "^12.1.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.2",
    "vite": "^6.1.1",
    "vitest": "^3.0.7"
  }
}
